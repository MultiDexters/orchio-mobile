# ─────────────────────────────────────────────────────────────────────────────
# Orchio — app environment (safe to ship; these are public client keys only).
# Copy to `.env` and fill in. Never put server secrets (OpenAI, service role) here.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Picovoice Porcupine access key (https://console.picovoice.ai)
EXPO_PUBLIC_PICOVOICE_ACCESS_KEY=YOUR-PICOVOICE-ACCESS-KEY

# Optional: which STT engine to use by default. one of: ondevice | deepgram
EXPO_PUBLIC_STT_ENGINE=ondevice

# Only set this if you choose to run Deepgram STT *client-side* (not recommended).
# Prefer server-side STT via the edge function so this key never ships in the app.
# EXPO_PUBLIC_DEEPGRAM_API_KEY=
